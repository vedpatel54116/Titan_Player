			);
			inputPaths = (
			);
			name = "Run Script";
			outputFileListPaths = (
			);
			outputPaths = (
			);
			runOnlyForDeploymentPostprocessing = 0;
			shellPath = /bin/sh;
			shellScript = "set -euo pipefail\nSHADER_DIR=\"${SRCROOT}/TitanPlayer/Resources/Shaders\"\nOUTPUT_DIR=\"${BUILT_PRODUCTS_DIR}/${UNLOCALIZED_RESOURCES_FOLDER_PATH}\"\nmkdir -p \"${OUTPUT_DIR}\"\nmkdir -p \"${DERIVED_FILE_DIR}/Metal\"\nMETAL_FILES=()\nwhile IFS= read -r -d '' file; do\n  METAL_FILES+=(\"$file\")\ndone < <(find \"${SHADER_DIR}\" -name \"*.metal\" -print0)\nif [ ${#METAL_FILES[@]} -eq 0 ]; then\n  echo \"warning: No .metal files found in ${SHADER_DIR}\"\n  exit 0\nfi\nxcrun metal -c \"${METAL_FILES[@]}\" \\\n  -I \"${SHADER_DIR}\" \\\n  -o \"${DERIVED_FILE_DIR}/Metal/default.air\"\nxcrun metallib \"${DERIVED_FILE_DIR}/Metal/default.air\" \\\n  -o \"${OUTPUT_DIR}/default.metallib\"\necho \"Compiled Metal shaders → ${OUTPUT_DIR}/default.metallib\"\n";
		};
		FAB7914D28523A347A1397BA /* Run Script */ = {
