			shellPath = /bin/sh;
			shellScript = "set -euo pipefail\ncd \"${SRCROOT}/TitanPlayer\"\nCONFIG_LOWER=$(echo \"${CONFIGURATION}\" | tr '[:upper:]' '[:lower:]')\ncase \"${CONFIG_LOWER}\" in\n  debug)   swift build -c debug  ;;\n  *)       swift build -c release ;;\nesac\nmkdir -p \"${BUILT_PRODUCTS_DIR}/${EXECUTABLE_FOLDER_PATH}\"\nDEST=\"${BUILT_PRODUCTS_DIR}/${EXECUTABLE_FOLDER_PATH}/TitanPlayer\"\ncp \".build/${CONFIG_LOWER}/TitanPlayer\" \"${DEST}\"\necho \"embedded swiftrm executable at ${DEST}\"\n";
		};
